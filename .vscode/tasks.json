{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo: check",
      "type": "process",
      "command": "cargo",
      "args": [
        "check"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": "build",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: build (debug)",
      "type": "process",
      "command": "cargo",
      "args": [
        "build"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: run source",
      "type": "process",
      "command": "cargo",
      "args": [
        "run",
        "--",
        "${input:sourceFile}"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": "build",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: run source (verbose)",
      "type": "process",
      "command": "cargo",
      "args": [
        "run",
        "--",
        "--verbose",
        "${input:sourceFile}"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": "build",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: rebuild frontend and run source",
      "type": "process",
      "command": "cargo",
      "args": [
        "run",
        "--",
        "--rebuild",
        "--verbose",
        "${input:sourceFile}"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": "build",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: test",
      "type": "process",
      "command": "cargo",
      "args": [
        "test"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: test (show output)",
      "type": "process",
      "command": "cargo",
      "args": [
        "test",
        "--",
        "--nocapture"
      ],
      "problemMatcher": [
        "$rustc"
      ],
      "group": "test",
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "cargo: clean",
      "type": "process",
      "command": "cargo",
      "args": [
        "clean"
      ],
      "problemMatcher": [],
      "presentation": {
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "sourceFile",
      "type": "promptString",
      "description": "Compiler input source file",
      "default": "example_source/source1.txt"
    }
  ]
}

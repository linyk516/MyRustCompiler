{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyRustCompiler GUI",
  "version": "0.1.0",
  "identifier": "com.myrustcompiler.gui",
  "build": {
    "beforeDevCommand": "npm --prefix gui run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix gui run build",
    "frontendDist": "gui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyRustCompiler",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}

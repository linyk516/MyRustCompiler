[
  {
    "label": "cargo: check",
    "command": "cargo",
    "args": ["check"],
    "save": "all",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cargo: build (debug)",
    "command": "cargo",
    "args": ["build"],
    "save": "all",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cargo: run example source",
    "command": "cargo",
    "args": ["run", "--", "example_source/source1.txt"],
    "save": "all",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cargo: run example source (verbose)",
    "command": "cargo",
    "args": ["run", "--", "--verbose", "example_source/source1.txt"],
    "save": "all",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cargo: rebuild frontend and run example source",
    "command": "cargo",
    "args": [
      "run",
      "--",
      "--rebuild",
      "--verbose",
      "example_source/source1.txt",
    ],
    "save": "all",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cargo: run current file as compiler input",
    "command": "cargo",
    "args": ["run", "--", "$ZED_FILE"],
    "save": "all",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "cargo: test",
    "command": "cargo",
    "args": ["test"],
    "save": "all",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "tags": ["rust-test"],
  },
  {
    "label": "cargo: test (show output)",
    "command": "cargo",
    "args": ["test", "--", "--nocapture"],
    "save": "all",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cargo: clean",
    "command": "cargo",
    "args": ["clean"],
    "save": "none",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
]
